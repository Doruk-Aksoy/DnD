Actor DNDDecor
{
  Radius 8
  Height 4
  -SOLID
  -SHOOTABLE
  +FLOORCLIP
  +NOINTERACTION
  +CLIENTSIDEONLY
  States
  {
  Spawn:
    TNT1 A 1
    stop
  }
}

// light sources
Actor DNDChandelier : DNDDecor 15001
{
  //$Category Light sources
  //$Title "DNDChandelier"
  //$Sprite CHDLA0
  +SPAWNCEILING
  States
  {
  Spawn:
    CHDL ABC 3 Bright
    Loop
  }
}

