// barrel
Actor DNDBarrelChip
{
  Scale 1.4
  Bouncefactor 0.6
  BounceCount 3
  Radius 8
  Height 8
  Speed 8
  seesound none
  Mass 1
  +MISSILE
  +NOBLOCKMAP
  +NOTELEPORT
  +DOOMBOUNCE
  +MOVEWITHSECTOR
  +CLIENTSIDEONLY
  -TELESTOMP
  +NOTELESTOMP
  +DROPOFF
  states
  {
  Spawn:
    WOOD A 0
    "####" A 0 A_Jump(128, 2)
    "####" D 2
    "####" D 0
    Goto SpawnLoop
  SpawnLoop:
    "####" A 0
    "####" A 0 A_JumpIf(waterlevel > 1, "Death2")
    "####" ABCD 2
    loop
  Death:
    "####" B 350
    Stop
  Death2:
    TNT1 A 1
    Stop
  }
}

actor DNDBarrelSmoke
{
  RenderStyle Translucent
  +NOINTERACTION
  +CLIENTSIDEONLY
  +NOBLOCKMAP
  +NOGRAVITY
  +NOTELEPORT
  -TELESTOMP
  +NOTELESTOMP
  Alpha 0.5
  Scale 0.9
  States
  {
  Spawn:
    SMOK GHIJKLMNOPQ 1
    Stop
  }
}

ACTOR DNDBarrel
{
  Health 50
  Radius 12
  Height 40
  YScale 1.2
  Mass 150
  MaxStepHeight 32
  +SOLID
  +SHOOTABLE
  +FLOORCLIP
  +DONTGIB
  +PUSHABLE
  -NOGRAVITY
  +NOBLOOD
  +NOICEDEATH
  -TELESTOMP
  +MOVEWITHSECTOR
  pushfactor 0.5
  States
  {
  Spawn:
    BARL A -1
    Stop
  Death:
    TNT1 A 1
    Goto DeathGibs
  DeathGibs:
    TNT1 A 0 A_NoBlocking
    TNT1 A 0 A_PlaySound("barrel/break")
    TNT1 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA 0 A_SpawnItemEx("DNDBarrelChip", random(-8, 8), random(-8, 8), random(8, 24), random(0, 5), random(0, 5), random(2, 8), random(1, 360), 0, 64)
    TNT1 AAAA 0 A_SpawnItemEx("DNDBarrelSmoke", random(-8, 8), random(-8, 8), random(4, 28), 0, 0, 0, 0, 0, 64)
    TNT1 A 1
    Stop
  }
}

ACTOR DNDBarrelRandomItemRare : DNDBarrel 16000
{
  //$Category Obstacles/DNDObstacles
  //$Title "Barrel Rarely Random Item"
  //$Sprite BARLA0
  States
  {
  Death:
    TNT1 A 1 A_SpawnItemEx("DNDRandomItemRareSpawner", 0, 0, 16)
    Goto DeathGibs
  }
}

