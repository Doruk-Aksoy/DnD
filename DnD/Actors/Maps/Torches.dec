//////////////////////
// SPECIAL FX BLOCK //
//////////////////////

// torches sfx
actor OSTorchFlare
{
  +NOBLOCKMAP
  +NOTELEPORT
  +NOGRAVITY
  +NOINTERACTION
  +FORCEXYBILLBOARD
  +BRIGHT
  +CLIENTSIDEONLY
  RenderStyle Add
  Alpha 1
  Radius 1
  Height 2
  Scale 0.25
  Stamina 0
  States
  {
  Spawn:
    FTA0 A 0
    "####" "#" 0 A_JumpIf(IsPointerEqual(AAPTR_MASTER, AAPTR_NULL), 2)
    "####" "#" 2 A_Warp(AAPTR_MASTER, 0, 0, stamina, 0, WARPF_NOCHECKPOSITION)
    Goto Spawn+1
    TNT1 A 1
    Stop
  } 
}
actor OSTorchFlareRed : OSTorchFlare { States { Spawn: FTA0 R 0
    Goto Super::Spawn+1 } }
