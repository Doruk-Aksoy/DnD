// ceiling cauldron torches
Actor OSCeilingTorch : OSWallTorch 12514
{
  +SPAWNCEILING
  +FORCEYBILLBOARD
  Height 58
  States
  {
  Spawn:
    CCAU A 0
    CCAU A 0 ACS_NamedExecuteWithResult("OS_Spawn_Torch_Flare", 17, 10)
    CCAU A 0 ACS_NamedExecuteWithResult("OS_Torch_Sound_Loop", 0)
    CCAU A 0 bright A_CheckSightOrRange(2000, 2)
    CCAU A 0 bright A_SpawnItemEx("OSWallTorchFlame", frandom(-2.0, 2.0), frandom(-2.0, 2.0), frandom(8.0, 12.0), frandom(0.01, 0.2), frandom(0.01, 0.2), frandom(1.2, 1.4), random(1, 360))
    CCAU A 2 bright
    goto Spawn+3
  Active:
    CCAU A 0 A_PlaySound("torch/light")
    CCAU A 0 A_Jump(256, "Spawn")
    Wait
  Inactive:
    CCAX A 0 A_RemoveChildren(1)
    CCAX A -1 A_StopSound(4)
    Stop
  }
}
Actor OSCeilingTorchOrange : OSCeilingTorch {}
