///////////////////
// TORCHES BLOCK //
///////////////////

// wall torches
Actor OSWallTorch : SwitchableDecoration 12508
{
  Radius 6
  Height 23
  +FIXMAPTHINGPOS
  +NOGRAVITY
  -SOLID
  -SHOOTABLE
  +FLOORCLIP
  +NOINTERACTION
  -CLIENTSIDEONLY
  +FORCEYBILLBOARD
  States
  {
  Spawn:
    WLTR I 0
    WLTR I 0 ACS_NamedExecuteWithResult("OS_Spawn_Torch_Flare", 17, 26)
    WLTR I 0 ACS_NamedExecuteWithResult("OS_Torch_Sound_Loop", 0)
    WLTR I 0 bright A_CheckSightOrRange(2000, 2)
    WLTR I 0 bright A_SpawnItemEx("OSWallTorchFlame", frandom(-2.0, 2.0), frandom(-2.0, 2.0), frandom(24.0, 28.0), frandom(0.01, 0.2), frandom(0.01, 0.2), frandom(1.2, 1.4), random(1, 360))
    WLTR I 2 bright
    goto Spawn+3
  Active:
    WLTR I 0 A_PlaySound("torch/light")
    WLTR I 0 A_Jump(256, "Spawn")
    Wait
  Inactive:
    WLTX A 0 A_RemoveChildren(1)
    WLTX A -1 A_StopSound(4)
    Stop
  }
}
Actor OSWallTorchOrange : OSWallTorch {}
