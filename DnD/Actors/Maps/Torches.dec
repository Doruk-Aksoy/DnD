// torch effects (sprite from Psychophobia)
actor OSTorchFlame
{
  Scale 0.15
  RenderStyle Add
  Alpha 1.0
  +NOBLOCKMAP
  +NOTELEPORT
  +NOGRAVITY
  +CLIENTSIDEONLY
  +NOINTERACTION
  +FORCEXYBILLBOARD
  +BRIGHT
  var int user_random_flip_xy;
  States
  {
  Spawn:
    TOFX A 0
    "####" "#" 0 
    "####" "#" 0 A_SetUserVar("user_random_flip_xy", 1 - 2 * random(0, 1))
    "####" "#" 0 A_SetScale(scaleX * user_random_flip_xy)
    "####" A 2 A_Jump(64, 1)
    "####" B 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" C 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" D 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" E 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" F 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" G 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" H 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" "#" 0 A_FadeOut(0.14)
    "####" A 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" "#" 0 A_JumpIf(scaleX < 0.01, "Done")
    "####" "#" 0 A_FadeOut(0.14)
    "####" B 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" "#" 0 A_FadeOut(0.14)
    "####" C 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" "#" 0 A_FadeOut(0.14)
    "####" D 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" "#" 0 A_FadeOut(0.14)
    "####" E 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" "#" 0 A_FadeOut(0.14)
    "####" F 2 A_SetScale(scaleX - (0.012 * user_random_flip_xy))
    "####" "#" 0 A_FadeOut(0.14)
    "####" G 2
    stop
  Done:
    TNT1 A 1
    stop
  }
}
