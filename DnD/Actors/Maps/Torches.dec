  Spawn:
    WLTR I 0
    WLTR I 0 ACS_NamedExecuteWithResult("OS_Spawn_Torch_Flare", 16, 26)
    WLTR I 0 ACS_NamedExecuteWithResult("OS_Torch_Sound_Loop", 0)
    WLTR I 0 bright A_CheckSightOrRange(2000, 2)
    WLTR I 0 bright A_SpawnItemEx("OSWallTorchFlameRed", frandom(-2.0, 2.0), frandom(-2.0, 2.0), frandom(24.0, 28.0), frandom(0.01, 0.2), frandom(0.01, 0.2), frandom(1.2, 1.4), random(1, 360))
    WLTR I 2 bright
    goto Spawn+3
  }
}
