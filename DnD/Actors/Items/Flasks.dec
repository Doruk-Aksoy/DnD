enum {
    DND_FLASK_LIFE_SMALL,
    DND_FLASK_LIFE_MEDIUM,
    DND_FLASK_LIFE_LARGE,
    DND_FLASK_LIFE_GRAND,
    DND_FLASK_LIFE_EXQUISITE
};

Actor Flask1_Type : Ammo {
    inventory.amount 1
	inventory.maxamount 100
    ammo.backpackamount 0
    +IGNORESKILL
}
Actor Flask2_Type : Ammo {
    inventory.amount 1
	inventory.maxamount 100
    ammo.backpackamount 0
    +IGNORESKILL
}

Actor Flask1_CurrentCharges : Ammo {
    inventory.maxamount 100
    inventory.amount 1
    ammo.backpackamount 0
    +IGNORESKILL
}

Actor Flask2_CurrentCharges : Ammo {
    inventory.maxamount 100
    inventory.amount 1
    ammo.backpackamount 0
    +IGNORESKILL
}

Actor Flask1_TicCounter : Ammo {
    inventory.maxamount 100
    inventory.amount 1
    ammo.backpackamount 0
    +IGNORESKILL
}

Actor Flask2_TicCounter : Ammo {
    inventory.maxamount 100
    inventory.amount 1
    ammo.backpackamount 0
    +IGNORESKILL
}

Actor Flask1_CritCooldown : PowerProtection {
    damagefactor "normal", 1.0
    powerup.duration 7 // 0.2 sec cd
}

Actor Flask2_CritCooldown : PowerProtection {
    damagefactor "normal", 1.0
    powerup.duration 7 // 0.2 sec cd
}

Actor FlaskSoundPlayer : CustomInventory {
	States {
		Pickup:
			TNT1 A 0 A_PlaySound("Items/FlaskDrop")
			TNT1 A 0 A_SetBlend("25 99 25", 0.6, 17)
		Stop
	}
}

Actor FlaskDrop : InventoryBase {
	Height 24
    Radius 20
	States {
		Spawn:
			TNT1 A 0
		Goto SpawnInit
		
		SpawnLoop:
		Idle:
			TNT1 AAAAAAAAAAAAAAAA 1 Bright A_LookEx(LOF_NOSOUNDCHECK, 0, item_look_dist, 0, 360, "CheckPickup")
		Loop

        PickupSuccess:
			TNT1 A 8 ACS_NamedExecuteAlways("DnD Flask Item Pickup", 0, mass - 1)
		stop
	}
}

Actor FlaskDrop_Life_0 : FlaskDrop {
    States {
        Spawn:
            FLS1 A 0
        Goto SpawnInit

        SpawnLoop:
        Idle:
			FLS1 AAAAABBBBBCCCCC 1 Bright A_LookEx(LOF_NOSOUNDCHECK, 0, item_look_dist, 0, 360, "CheckPickup")
		Loop
    }
}

